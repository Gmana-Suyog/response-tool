{
  "name": "hls-qa-tool-server",
  "version": "1.0.0",
  "description": "Backend server for HLS QA Tool",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "dev": "nodemon index.js"
  },
  "nodemonConfig": {
    "ignore": [
      "hls/*",
      "hls/**/*",
      "dash/*",
      "dash/**/*",
      "mp4/*",
