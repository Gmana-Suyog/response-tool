  "dependencies": {
    "archiver": "^6.0.1",
    "axios": "^1.6.2",
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "fast-xml-parser": "^5.3.6",
    "fs-extra": "^11.2.0",
    "jsonwebtoken": "^9.0.3",
    "m3u8-parser": "^7.1.0",
    "mongoose": "^8.0.3",
    "mpd-parser": "^1.3.1",
    "uuid": "^9.0.1"
