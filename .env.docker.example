# Docker Environment Configuration
# Copy this file to .env and update the values

# JWT Secrets (CHANGE THESE IN PRODUCTION!)
JWT_SECRET=your_secure_jwt_secret_key_here_change_me
REFRESH_TOKEN_SECRET=your_secure_refresh_token_secret_key_here_change_me

# Optional: Override default ports
# SERVER_PORT=3001
# CLIENT_PORT=3000
# MONGODB_PORT=27017

# Optional: Override MongoDB connection
# MONGODB_URI=mongodb://mongodb:27017/hls-qa-tool

# Optional: Override server base URL
# SERVER_BASE_URL=http://localhost:3001
